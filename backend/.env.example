# Server Configuration
PORT=5001
NODE_ENV=development

# Database - MongoDB Atlas
# Replace with your actual MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/stayhub?retryWrites=true&w=majority

# JWT Authentication
# Generate a strong secret (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-32-characters-long
JWT_EXPIRATION=1h

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Google Cloud Storage (Optional but recommended for production)
# Get these from Google Cloud Console
GCP_PROJECT_ID=stayhub-489907
GCS_BUCKET=stayhub_bucket

# Path to GCS service account JSON key file
# Download from Google Cloud Console → Service Accounts
# NEVER commit this file to Git!
GOOGLE_APPLICATION_CREDENTIALS=./stayhub-489907-0e76df346af1.json
